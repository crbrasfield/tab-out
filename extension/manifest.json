{
  "manifest_version": 3,
  "name": "Tab Out",
  "version": "1.0.0",
  "description": "A local new tab page for saving tabs for later and managing deferred reading lists.",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["http://localhost:3456/*"],
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
